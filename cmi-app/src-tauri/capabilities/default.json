{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for the CMI desktop window.",
  "windows": ["main"],
  "remote": {
    "urls": ["http://127.0.0.1:4000/**"]
  },
  "permissions": [
    "core:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "cloudflared", "sidecar": true, "args": true },
        { "name": "node",        "sidecar": true, "args": true }
      ]
    }
  ]
}

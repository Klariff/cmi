{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CMI",
  "version": "0.1.0",
  "identifier": "com.klariff.cmi",
  "build": {
    "beforeDevCommand": "npm --prefix ../cmi-back start",
    "devUrl": "http://127.0.0.1:4000",
    "beforeBuildCommand": "node scripts/build-frontend.js",
    "frontendDist": "../../cmi-back/public"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CMI",
        "url": "http://127.0.0.1:4000",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "signingIdentity": "-",
      "entitlements": "Entitlements.plist"
    },
    "externalBin": [
      "binaries/cloudflared",
      "binaries/node"
    ],
    "resources": {
      "../../cmi-back/src":          "cmi-back/src",
      "../../cmi-back/node_modules": "cmi-back/node_modules",
      "../../cmi-back/public":       "cmi-back/public",
      "../../cmi-back/package.json": "cmi-back/package.json"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
